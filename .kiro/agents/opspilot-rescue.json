{
  "name": "opspilot-rescue",
  "description": "Workspace agent for OpsPilot Rescue. Start from .claude canon, keep financing scout as the hero live lane, and protect deterministic finance truth.",
  "includeMcpJson": true,
  "resources": [
    "file://.claude/README.md",
    "file://.claude/PRD.md",
    "file://.claude/context/current-state.md",
    "file://.claude/context/12hour-execution.md",
    "file://.claude/context/architecture.md",
    "file://.claude/playbooks/tinyfish-and-agent.md",
    "file://.claude/playbooks/ui-and-demo.md",
    "file://.claude/checklists/change-gate.md",
    "file://docs/rescue-demo-runbook.md",
    "file://docs/kiro-tinyfish-setup.md",
    "file://docs/apprunner-deploy.md",
    "skill://.kiro/skills/**/SKILL.md"
  ],
  "welcomeMessage": "Read .claude/README.md first. Keep financing scout as the only required live external lane, and do not move deterministic finance truth into AI.",
  "hooks": {
    "agentSpawn": [
      {
        "command": "bash .kiro/hooks/canon-gate.sh agentSpawn",
        "timeout_ms": 5000
      }
    ],
    "userPromptSubmit": [
      {
        "command": "bash .kiro/hooks/canon-gate.sh userPromptSubmit",
        "timeout_ms": 5000
      }
    ],
    "postToolUse": [
      {
        "matcher": "write",
        "command": "bash .kiro/hooks/secret-hygiene.sh",
        "timeout_ms": 15000
      },
      {
        "matcher": "write",
        "command": "bash .kiro/hooks/demo-safety.sh postToolUse",
        "timeout_ms": 15000
      }
    ],
    "stop": [
      {
        "command": "bash .kiro/hooks/demo-safety.sh stop",
        "timeout_ms": 15000
      }
    ]
  }
}
