# Copy to .env.local — never commit real secrets.

# Supabase (NEXT_PUBLIC_* are safe for the browser bundle)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only — required for API routes that use createServerSupabaseClient / getServerEnv
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Demo org UUID (must match seed organizations.id)
DEMO_ORG_ID=00000000-0000-0000-0000-000000000001

# Anthropic — optional; manager summary + review analysis fall back deterministically without it
ANTHROPIC_API_KEY=

# Webhook ingress (production requires secret). Under `next dev`, unsigned POSTs are allowed when the secret is unset.
# Use INTEGRATIONS_WEBHOOK_SECRET for signed curls, or uncomment INTEGRATIONS_WEBHOOK_ALLOW_UNSIGNED=true for local/test replay flows.
INTEGRATIONS_WEBHOOK_SECRET=
# INTEGRATIONS_WEBHOOK_ALLOW_UNSIGNED=true

# Cron-style routes (e.g. POST /api/ai/manager-summary) — required in production when CRON_SECRET is set
CRON_SECRET=

# Other optional integrations
GOOGLE_AI_API_KEY=

# --- TinyFish (optional, server-only) ----------------------------------------
# TinyFish powers the SMB "survival agent" demo (financing scout, vendor cost
# compare, insurance renewal). The repo ships with deterministic mock fixtures,
# so leaving these unset is safe — routes fall back to mock mode.
TINYFISH_API_KEY=
TINYFISH_BASE_URL=https://agent.tinyfish.ai
# Turn on live mode explicitly. Default false.
TINYFISH_ENABLED=false
# Force-mock fixtures even when a key is present. Default true for demo safety.
TINYFISH_USE_MOCKS=true
# Request timeout for live TinyFish calls. Default 30000.
TINYFISH_TIMEOUT_MS=30000
# Per-method paths. Live mode is only considered "fully configured" when all
# four are set. If missing, methods gracefully return a misconfigured result
# instead of hitting the network.
TINYFISH_SEARCH_PATH=
TINYFISH_FETCH_PATH=
TINYFISH_AGENT_PATH=
TINYFISH_HEALTH_PATH=

# --- AWS (optional) ----------------------------------------------------------
# Used by optional S3 evidence helper (src/lib/aws/s3.ts). Missing values =>
# helper no-ops. Not required for local dev or hackathon mock demo.
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Demo mode ---------------------------------------------------------------
# Default true. Set to "false" to disable demo-only affordances (e.g.
# deterministic UUIDs in /api/tinyfish/demo-run audit logging).
DEMO_MODE=true
